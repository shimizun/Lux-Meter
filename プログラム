/**
 * Wio Terminal High-Performance Lux Meter
 * * 機能:
 * 1. VEML7700を使用した高精度照度測定
 * 2. オートレンジ機能（自動感度調整）
 * 3. ログスケール（対数）トレンドグラフ表示
 * 4. ダブルバッファリング（スプライト）によるチラつき防止
 */

#include <Wire.h>
#include "Adafruit_VEML7700.h"
#include <TFT_eSPI.h> 
#include <SPI.h>

// センサーと画面のインスタンス作成
Adafruit_VEML7700 veml = Adafruit_VEML7700();
TFT_eSPI tft = TFT_eSPI();

// --- スプライト（裏画面）の定義 ---
// 画面に直接描くとチラつくため、メモリ上に「仮想画面」を2つ作ります
TFT_eSprite textSpr = TFT_eSprite(&tft);  // 上部（数値表示用）
TFT_eSprite graphSpr = TFT_eSprite(&tft); // 下部（グラフ表示用）

// --- 設定パラメータ ---
// 画面サイズ: 320x240
#define GRAPH_H 80        // グラフエリアの高さ (画面の1/3)
#define GRAPH_Y 160       // グラフの開始Y座標 (240 - 80)
#define HISTORY_NUM 320   // 履歴データの保存数 (画面の横幅分)
#define UPDATE_WAIT 500   // 更新待機時間 (ms) -> 0.5秒ごとに更新

// --- グローバル変数 ---
float history[HISTORY_NUM]; // 照度履歴を保存する配列（リングバッファ）
int headIndex = 0;          // 最新データ書き込み位置のインデックス
bool highSens = false;      // 現在が高感度モードかどうかのフラグ

void setup() {
  // 1. 基本ハードウェア初期化
  Serial.begin(115200);
  tft.begin();
  tft.setRotation(3);       // 横向き（ボタンが右側に来る向き）
  tft.fillScreen(TFT_BLACK);

  // 2. スプライト（裏画面）のメモリ確保 ★重要★
  // Wio TerminalのRAMは限りがあるため、全画面分の裏画面を作るとメモリ不足で動かなくなります。
  // そのため、色情報を「16bit(6万色)」から「8bit(256色)」に落としてメモリ消費を半分に節約します。
  textSpr.setColorDepth(8);
  graphSpr.setColorDepth(8);

  // 数値エリアのメモリ確保 (横320 x 縦160)
  if (textSpr.createSprite(320, GRAPH_Y) == nullptr) {
    // メモリ確保失敗時のエラー処理
    tft.drawString("Memory Error: TextSprite", 0, 0); 
    while(1);
  }
  // グラフエリアのメモリ確保 (横320 x 縦80)
  if (graphSpr.createSprite(320, GRAPH_H) == nullptr) {
    tft.drawString("Memory Error: GraphSprite", 0, 0); 
    while(1);
  }

  // 3. センサー初期化
  if (!veml.begin()) {
    tft.setTextColor(TFT_RED);
    tft.drawString("SENSOR ERROR: Check Wiring", 10, 100);
    while (1);
  }

  // 4. センサー初期設定
  // 積分時間100ms: 高速応答のため短めに設定
  veml.setIntegrationTime(VEML7700_IT_100MS);
  // 初期ゲイン: 広範囲モード(1/8倍)から開始
  veml.setGain(VEML7700_GAIN_1_8); 
  
  // 履歴配列を0でリセット
  for(int i=0; i<HISTORY_NUM; i++) history[i] = 0;
}

void loop() {
  // --- A. 計測 ---
  float lux = veml.readLux();
  if(lux < 0) lux = 0; // マイナス値（エラー）は0として扱う

  // --- B. オートレンジ処理 (ヒステリシス制御) ---
  // 閾値付近でパチパチ切り替わらないよう、上げ下げの基準に差をつけています
  
  // 暗い場合 (100lx以下) -> 高感度モードへ
  if (!highSens && lux < 100) {
    veml.setGain(VEML7700_GAIN_2); // 最大感度(2倍)
    highSens = true;
  }
  // 明るい場合 (200lx以上) -> 広範囲モードへ
  else if (highSens && lux > 200) { 
    veml.setGain(VEML7700_GAIN_1_8); // 最小感度(1/8倍)
    highSens = false;
  }

  // ==========================================
  //  C. 描画処理 (裏画面への書き込み)
  // ==========================================

  // --- C-1. 上部エリア (数値表示) の描画 ---
  textSpr.fillSprite(TFT_BLACK); // まず裏画面を真っ黒に消す

  // 数値の描画
  textSpr.setTextColor(TFT_WHITE);
  textSpr.setTextDatum(MC_DATUM); // 座標の基準を「文字の中心」にする
  textSpr.setTextSize(7);         // 特大フォント
  textSpr.drawFloat(lux, 1, 160, 70); // x=160(中央), y=70 の位置に描画

  // 単位「lux」の描画
  textSpr.setTextSize(2);
  textSpr.setTextColor(TFT_LIGHTGREY);
  textSpr.drawString("lux", 160, 120);

  // 右上のモード表示（デバッグ用情報）
  textSpr.setTextSize(1);
  textSpr.setTextDatum(TR_DATUM); // 座標基準を「右上」にする
  if(highSens) textSpr.drawString("High Sens (x2)", 310, 10);
  else         textSpr.drawString("Wide Range (x1/8)", 310, 10);
  
  // エリア境界線の描画
  textSpr.drawFastHLine(0, GRAPH_Y - 1, 320, TFT_DARKGREY);


  // --- C-2. グラフデータの更新 (リングバッファ) ---
  // 最新の値を配列の「現在の頭」に書き込む
  history[headIndex] = lux;
  // 書き込み位置を一つ進める（最後まで行ったら0に戻る＝リング状）
  headIndex = (headIndex + 1) % HISTORY_NUM;


  // --- C-3. 下部エリア (グラフ) の描画 ---
  graphSpr.fillSprite(TFT_BLACK); // グラフエリアをクリア

  // ガイドライン（グリッド）を描く
  graphSpr.drawFastHLine(0, 0, 320, 0x2104);       // 上端の線
  graphSpr.drawFastHLine(0, GRAPH_H/2, 320, 0x2104); // 真ん中の線

  // 過去のデータをつないで線を描画
  for (int i = 0; i < HISTORY_NUM - 1; i++) {
    // リングバッファから「古い順」にデータを取り出すための計算
    int idx = (headIndex + i) % HISTORY_NUM;
    int nextIdx = (headIndex + i + 1) % HISTORY_NUM;
    
    float v1 = history[idx];
    float v2 = history[nextIdx];

    // --- 対数圧縮計算 (Log Scale) ---
    // 人間の目は明るさを対数で感じるため、log10を使ってグラフ化します。
    // log10(10) = 1, log10(100) = 2, log10(10000) = 4
    // グラフの高さ(GRAPH_H)に合わせてスケーリングします。
    
    int y1 = 0; 
    if(v1 > 0) y1 = (int)(log10(v1) * (GRAPH_H / 4.0)); // 最大10000lux(log=4)想定
    
    int y2 = 0; 
    if(v2 > 0) y2 = (int)(log10(v2) * (GRAPH_H / 4.0));
    
    // 座標系の変換:
    // 画面は上が0なので、グラフを下から生やすために「高さ - 値」で反転させる
    y1 = GRAPH_H - constrain(y1, 0, GRAPH_H);
    y2 = GRAPH_H - constrain(y2, 0, GRAPH_H);

    // 点と点をつなぐ線を描画
    graphSpr.drawLine(i, y1, i+1, y2, TFT_GREEN);
  }

  // ==========================================
  //  D. 画面転送 (プッシュ)
  // ==========================================
  // 裏画面で完成させた絵を一瞬で表画面に転送します。
  // これにより、書き換え途中のチラチラが一切見えなくなります。
  
  textSpr.pushSprite(0, 0);       // 上半分を転送
  graphSpr.pushSprite(0, GRAPH_Y); // 下半分を転送

  // 次の測定まで待機
  delay(UPDATE_WAIT); 
}
